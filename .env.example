# Base de datos
# Desarrollo: DATABASE_URL="file:./dev.db"
# Produccion: DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./dev.db"

# NextAuth (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET="tu-clave-secreta-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
